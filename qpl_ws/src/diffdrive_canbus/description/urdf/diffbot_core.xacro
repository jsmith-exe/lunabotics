<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="gray"><color rgba="0.6 0.6 0.6 1.0"/></material>
  <material name="black"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="red"><color rgba="0.8 0.1 0.1 1.0"/></material>
  <material name="blue"><color rgba="0.2 0.2 1.0 1.0"/></material>

  <xacro:property name="base_x" value="0.50"/>
  <xacro:property name="base_y" value="0.30"/>
  <xacro:property name="base_z" value="0.18"/>

  <xacro:property name="wheel_r" value="0.08"/>
  <!-- base_link is located above the ground by wheel radius + half the base height -->
  <xacro:property name="base_z_origin" value="${wheel_r + base_z/2}"/>

  <xacro:property name="wheel_w" value="0.03"/>

  <xacro:property name="wheel_x_front" value="0.18"/>
  <xacro:property name="wheel_x_rear"  value="-0.18"/>
  <xacro:property name="wheel_y" value="${base_y/2 + wheel_w/2}"/>
  <xacro:property name="wheel_z" value="${wheel_r}"/>

  <!-- 2D ground-projected base frame -->
  <link name="base_footprint"/>

  <!-- Body frame -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_z_origin}" rpy="0 0 0"/>
      <geometry><box size="${base_x} ${base_y} ${base_z}"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <!-- base_footprint -> base_link (base_link sits above ground) -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_z_origin}" rpy="0 0 0"/>
  </joint>


  <!-- WHEELS -->
  <xacro:macro name="wheel_link" params="name">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <material name="red"/>
      </visual>
    </link>



  </xacro:macro>

  <xacro:wheel_link name="front_left_wheel"/>
  <xacro:wheel_link name="front_right_wheel"/>
  <xacro:wheel_link name="rear_left_wheel"/>
  <xacro:wheel_link name="rear_right_wheel"/>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="${wheel_x_front} ${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="${wheel_x_front} -${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="${wheel_x_rear} ${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="${wheel_x_rear} -${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>