<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Mount camera to rover -->
  <joint name="camera_joint_front" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link_front"/>
    <origin xyz="0.465 0 0.02" rpy="0 0 0"/>
  </joint>

  <link name="camera_link_front">
    <visual>
      <geometry>
        <box size="0.010 0.03 0.03"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.010 0.03 0.03"/>
      </geometry>
    </collision>

    <!-- small inertia so Gazebo is happy -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <!-- Optical frame (REP-103/REP-105 style) -->
  <joint name="camera_optical_joint_front" type="fixed">
    <parent link="camera_link_front"/>
    <child link="camera_link_optical_front"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <link name="camera_link_optical_front"/>

  <!-- Two co-located Gazebo sensors so the color (AprilTag) and depth (point cloud)
       streams can run at different resolutions. A single depth-type sensor renders
       both from one <image> block, so we split them:
        - high-res color camera   -> /depth_camera_front/image_raw  (+ /camera_info)
        - 480p depth camera       -> /depth_camera_front_depth/points
       The color/info topics match the existing relays in sim.launch.py; the depth
       sensor lives in its own camera_name so its (unused) color image doesn't clash. -->
  <gazebo reference="camera_link_front">
    <material>Gazebo/Red</material>

    <!-- Color (visual) camera: full resolution for AprilTag detection (mirrors the
         front RealSense max of 1280x800). This is an expensive Gazebo render; if the
         sim can't keep up on a given machine, lowering this resolution (or the
         update_rate) is the first knob to turn. -->
    <sensor name="camera_front_color" type="camera">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>

      <camera>
        <horizontal_fov>1.51844</horizontal_fov>
        <image>
          <format>B8G8R8</format>
          <width>1280</width>
          <height>800</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>

      <plugin name="camera_front_color_controller" filename="libgazebo_ros_camera.so">
        <frame_name>camera_link_optical_front</frame_name>
        <camera_name>depth_camera_front</camera_name>
      </plugin>
    </sensor>

    <!-- Depth camera: 480p point cloud for the Nav2 voxel layer (mirrors the front
         RealSense depth at 848x480). -->
    <sensor name="depth_camera_front" type="depth">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>

      <camera>
        <horizontal_fov>1.51844</horizontal_fov>
        <image>
          <format>B8G8R8</format>
          <width>848</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>

      <plugin name="depth_camera_front_controller" filename="libgazebo_ros_camera.so">
        <frame_name>camera_link_optical_front</frame_name>
        <camera_name>depth_camera_front_depth</camera_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
