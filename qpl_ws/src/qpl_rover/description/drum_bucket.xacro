<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="inertial_macros.xacro"/>

  <!-- ========================================================= -->
  <!-- Drum bucket dimensions                                     -->
  <!-- ========================================================= -->

  <xacro:property name="drum_radius" value="0.10"/>
  <xacro:property name="drum_length" value="0.30"/>
  <xacro:property name="drum_mass"   value="1.0"/>

  <!-- Mount at middle of chassis (base_x / base_z come from rover_core) -->
  <xacro:property name="drum_x" value="${base_x/2 - 0.5}"/>
  <xacro:property name="drum_y" value="0.0"/>
  <xacro:property name="drum_z" value="${base_z/2 + drum_radius + 0.8}"/>

  <!-- Lift travel: 0.0 = fully down, 1.0 = fully up -->
  <xacro:property name="drum_lift_lower"    value="0.0"/>
  <xacro:property name="drum_lift_upper"    value="1.0"/>
  <xacro:property name="drum_lift_effort"   value="40.0"/>
  <xacro:property name="drum_lift_velocity" value="0.5"/>

  <!-- Spin limits -->
  <xacro:property name="drum_spin_effort"   value="50.0"/>
  <xacro:property name="drum_spin_velocity" value="10.0"/>

  <!-- ========================================================= -->
  <!-- Links                                                      -->
  <!-- ========================================================= -->

  <!-- Intermediate lift frame (massless carrier for prismatic joint) -->
  <link name="drum_lift_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Drum body -->
  <link name="drum_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${2*drum_radius} ${drum_length} ${2*drum_radius}"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${2*drum_radius} ${drum_length} ${2*drum_radius}"/>
      </geometry>
    </collision>

    <xacro:inertial_cylinder mass="${drum_mass}" length="${drum_length}" radius="${drum_radius}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <!-- ========================================================= -->
  <!-- Joints                                                     -->
  <!-- ========================================================= -->

  <!-- Prismatic lift along Z, anchored to chassis -->
  <joint name="drum_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drum_lift_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${drum_lift_lower}"
           upper="${drum_lift_upper}"
           effort="${drum_lift_effort}"
           velocity="${drum_lift_velocity}"/>
    <dynamics damping="5.0" friction="50.0"/>
  </joint>

  <!-- Continuous spin around Y, carries the X/Z offset to place drum at front -->
  <joint name="drum_spin_joint" type="continuous">
    <parent link="drum_lift_link"/>
    <child link="drum_link"/>
    <origin xyz="${drum_x} ${drum_y} ${drum_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="${drum_spin_effort}" velocity="${drum_spin_velocity}"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Gazebo                                                     -->
  <!-- ========================================================= -->

  <gazebo reference="drum_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo>
    <self_collide>0</self_collide>
  </gazebo>

</robot>
