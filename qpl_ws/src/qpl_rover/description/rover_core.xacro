<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="inertial_macros.xacro"/>

  <!-- Materials -->
  <material name="gray"><color rgba="0.6 0.6 0.6 1.0"/></material>
  <material name="black"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="red"><color rgba="0.8 0.1 0.1 1.0"/></material>
  <material name="blue"><color rgba="0.2 0.2 1.0 1.0"/></material>

  <!-- ========================================================= -->
  <!-- Main dimensions                                           -->
  <!-- ========================================================= -->

  <!-- Bottom cuboid -->
  <xacro:property name="base_x" value="0.875"/>
  <xacro:property name="base_y" value="0.599"/>
  <xacro:property name="base_z" value="0.135"/>

  <!-- Top trapezoid section -->
  <!-- top_x smaller than base_x gives the trapezoid side profile -->
  <xacro:property name="top_x" value="0.475"/>
  <xacro:property name="top_y" value="${base_y}"/>
  <xacro:property name="top_z" value="0.05"/>
  <xacro:property name="trap_height" value="0.225"/>

  <!-- Frame/support thickness -->
  <xacro:property name="frame_t" value="0.04"/>

  <!-- Wheel dimensions -->
  <xacro:property name="wheel_r" value="0.15"/>
  <xacro:property name="wheel_w" value="0.15"/>

  <!-- Wheel placement -->
  <xacro:property name="wheel_x_offset" value="${base_x / 2}"/>
  <xacro:property name="wheel_side_clearance" value="0.00"/>

  <!-- ========================================================= -->
  <!-- Derived values                                            -->
  <!-- ========================================================= -->

  <!-- Base lift -->
  <xacro:property name="base_link_z" value="${wheel_r + base_z / 2}"/>

  <!-- Wheel positions -->
  <xacro:property name="wheel_x_front" value="${wheel_x_offset}"/>
  <xacro:property name="wheel_x_rear" value="${-wheel_x_offset}"/>
  <xacro:property name="wheel_y" value="${base_y / 2 + wheel_w / 2 + wheel_side_clearance}"/>
  <xacro:property name="wheel_z" value="${-base_z / 2}"/>

  <!-- Top deck position -->
  <xacro:property name="top_deck_z" value="${base_z / 2 + trap_height + top_z / 2}"/>

  <!-- Slanted support geometry -->
  <xacro:property name="support_dx" value="${(base_x - top_x) / 2}"/>
  <xacro:property name="support_len" value="${math.sqrt(support_dx * support_dx + trap_height * trap_height)}"/>
  <xacro:property name="support_pitch" value="${math.atan2(trap_height, support_dx)}"/>

  <!-- Centres of support beams -->
  <xacro:property name="support_front_x" value="${(base_x + top_x) / 4}"/>
  <xacro:property name="support_rear_x" value="${-support_front_x}"/>
  <xacro:property name="support_y" value="${base_y / 2 - frame_t / 2}"/>
  <xacro:property name="support_z" value="${base_z / 2 + trap_height / 2}"/>

  <!-- ========================================================= -->
  <!-- Base frames                                               -->
  <!-- ========================================================= -->

  <link name="base_footprint"/>

  <!-- Bottom cuboid -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_x} ${base_y} ${base_z}"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_x} ${base_y} ${base_z}"/>
      </geometry>
    </collision>

    <xacro:inertial_box mass="10.0" x="${base_x}" y="${base_y}" z="${base_z}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_link_z}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- ========================================================= -->
  <!-- Generic box member macro                                  -->
  <!-- ========================================================= -->

  <xacro:macro name="box_member" params="name sx sy sz mass colour">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${sx} ${sy} ${sz}"/>
        </geometry>
        <material name="${colour}"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${sx} ${sy} ${sz}"/>
        </geometry>
      </collision>

      <xacro:inertial_box mass="${mass}" x="${sx}" y="${sy}" z="${sz}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <gazebo reference="${name}">
      <material>Gazebo/Grey</material>
    </gazebo>
  </xacro:macro>

  <!-- ========================================================= -->
  <!-- Upper trapezoid section                                   -->
  <!-- ========================================================= -->

  <!-- Top deck -->
  <xacro:box_member name="top_deck" sx="${top_x}" sy="${top_y}" sz="${top_z}" mass="2.0" colour="blue"/>

  <joint name="top_deck_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_deck"/>
    <origin xyz="0 0 ${top_deck_z}" rpy="0 0 0"/>
  </joint>

  <!-- Front supports -->
  <xacro:box_member name="front_left_support"  sx="${support_len}" sy="${frame_t}" sz="${frame_t}" mass="0.5" colour="black"/>
  <xacro:box_member name="front_right_support" sx="${support_len}" sy="${frame_t}" sz="${frame_t}" mass="0.5" colour="black"/>

  <joint name="front_left_support_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_support"/>
    <origin xyz="${support_front_x} ${support_y} ${support_z}" rpy="0 ${support_pitch} 0"/>
  </joint>

  <joint name="front_right_support_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_support"/>
    <origin xyz="${support_front_x} -${support_y} ${support_z}" rpy="0 ${support_pitch} 0"/>
  </joint>

  <!-- Rear supports -->
  <xacro:box_member name="rear_left_support"  sx="${support_len}" sy="${frame_t}" sz="${frame_t}" mass="0.5" colour="black"/>
  <xacro:box_member name="rear_right_support" sx="${support_len}" sy="${frame_t}" sz="${frame_t}" mass="0.5" colour="black"/>

  <joint name="rear_left_support_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_support"/>
    <origin xyz="${support_rear_x} ${support_y} ${support_z}" rpy="0 -${support_pitch} 0"/>
  </joint>

  <joint name="rear_right_support_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_support"/>
    <origin xyz="${support_rear_x} -${support_y} ${support_z}" rpy="0 -${support_pitch} 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Wheel macro                                               -->
  <!-- ========================================================= -->

  <xacro:macro name="wheel_link" params="name">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi / 2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_r}" length="${wheel_w}"/>
        </geometry>
        <material name="red"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${pi / 2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_r * 0.98}" length="${wheel_w * 0.95}"/>
        </geometry>
      </collision>

      <xacro:inertial_cylinder mass="0.5" length="${wheel_w}" radius="${wheel_r}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:inertial_cylinder>
    </link>

    <gazebo reference="${name}">
      <material>Gazebo/Red</material>
    </gazebo>

    <gazebo reference="${name}">
      <fdir1>1 0 0</fdir1>
      <mu1>1.4</mu1>
      <mu2>0.2</mu2>
      <slip1>0.0</slip1>
      <slip2>0.0</slip2>
    </gazebo>
  </xacro:macro>

  <!-- ========================================================= -->
  <!-- Wheels                                                    -->
  <!-- ========================================================= -->

  <xacro:wheel_link name="front_left_wheel"/>
  <xacro:wheel_link name="front_right_wheel"/>
  <xacro:wheel_link name="rear_left_wheel"/>
  <xacro:wheel_link name="rear_right_wheel"/>

  <!-- ========================================================= -->
  <!-- Wheel joints                                              -->
  <!-- ========================================================= -->

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="${wheel_x_front} ${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="${wheel_x_front} -${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="${wheel_x_rear} ${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="${wheel_x_rear} -${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>



<!-- Drum (placeholder primitive, prismatic lift + continuous spin) -->
  <xacro:property name="drum_radius" value="0.10"/>
  <xacro:property name="drum_length" value="0.30"/>
  <xacro:property name="drum_mass"   value="1.0"/>

  <!-- Mount at middle of chassis -->
  <xacro:property name="drum_x" value="${base_x/2}"/>
  <xacro:property name="drum_y" value="0.0"/>
  <xacro:property name="drum_z" value="${base_z/2 + drum_radius +0.25}"/>

  <!-- Drum lift travel: 0 = up (rest), -0.1 = lowered -->
  <xacro:property name="drum_lift_lower" value="-0.1"/>
  <xacro:property name="drum_lift_upper" value="0.0"/>
  <xacro:property name="drum_lift_effort" value="40.0"/>
  <xacro:property name="drum_lift_velocity" value="0.1"/>

  <!-- Drum spin limits -->
  <xacro:property name="drum_spin_effort" value="50.0"/>
  <xacro:property name="drum_spin_velocity" value="10.0"/>

  <!-- Intermediate frame -->
<link name="drum_lift_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="2.0"/>
    <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
  </inertial>
</link>


  <!-- Actual drum link: visual, collision, real inertia -->
  <link name="drum_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${2*drum_radius} ${drum_length} ${2*drum_radius}"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${2*drum_radius} ${drum_length} ${2*drum_radius}"/>
      </geometry>
    </collision>

    <xacro:inertial_cylinder mass="${drum_mass}" length="${drum_length}" radius="${drum_radius}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <!-- Lift joint: prismatic along Z. Origin stays at base_link,
       offset moved down to drum_spin_joint.  change to type prismatic -->

  <joint name="drum_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drum_lift_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${drum_lift_lower}"
           upper="${drum_lift_upper}"
           effort="${drum_lift_effort}"
           velocity="${drum_lift_velocity}"/>
    <dynamics damping="5.0" friction="50.0"/>
  </joint>

  <!-- Spin joint: continuous around Y. Carries the X/Z offset
       that places the drum at the front of the rover. -->
  <joint name="drum_spin_joint" type="continuous">
    <parent link="drum_lift_link"/>
    <child link="drum_link"/>
    <origin xyz="${drum_x} ${drum_y} ${drum_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="${drum_spin_effort}" velocity="${drum_spin_velocity}"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <gazebo reference="drum_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo>
  <self_collide>0</self_collide>
  </gazebo>
</robot>
