            </box>
          </geometry>
        </collision>
        <inertial>
          <mass>5</mass>
        </inertial>
      </link>
    </model>

    <model name="boulder_2">
      <pose>0.3 -2.95 0.15 0 0 0</pose>
      <static>1</static>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>0.3 0.3 0.3</size>
            </box>
          </geometry>
          <material>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.4 0.4 0.4 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.3 0.3 0.3</size>
            </box>
          </geometry>
        </collision>
        <inertial>
          <mass>5</mass>
        </inertial>
      </link>
    </model>

    <model name="boulder_3">
      <pose>0.9 -1.0 0.15 0 0 0</pose>
      <static>1</static>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>0.3 0.3 0.3</size>
            </box>
          </geometry>
          <material>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.4 0.4 0.4 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.3 0.3 0.3</size>
            </box>
          </geometry>
        </collision>
        <inertial>
          <mass>5</mass>
        </inertial>
      </link>
    </model>

    <!-- APRILTAG -->
    <model name="apriltag_0">
      <static>true</static>
      <pose>-2.145 -3.65 0.6 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.01 0.225 0.225</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.01 0.225 0.225</size></box></geometry>
          <material>
            <script>
              <uri>model://apriltag_model/materials/scripts/apriltag.material</uri>
              <uri>model://apriltag_model/materials/textures/</uri>
              <name>AprilTag/tag0</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>